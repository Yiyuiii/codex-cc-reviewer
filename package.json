{
  "name": "codex-cc-reviewer",
  "version": "0.1.0",
  "description": "Use Claude Code as an external reviewer from Codex.",
  "type": "module",
  "bin": {
    "codex-cc-reviewer": "dist/index.js"
  },
  "files": [
    "dist",
    "prompts",
    "examples",
    "docs/installation.md",
    "docs/manual-setup.md",
    "docs/codex-usage.md",
    "docs/security.md",
    "docs/tool-contract.md",
    "docs/troubleshooting.md",
    "docs/prior-art.md",
    "README.md",
    "README.zh-CN.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
