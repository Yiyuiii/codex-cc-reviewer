{
  "name": "codex-cc-reviewer",
  "version": "0.3.0",
  "description": "Use Claude Code as an external reviewer from Codex.",
  "homepage": "https://github.com/Yiyuiii/codex-cc-reviewer#readme",
  "bugs": {
    "url": "https://github.com/Yiyuiii/codex-cc-reviewer/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yiyuiii/codex-cc-reviewer.git"
  },
  "type": "module",
  "bin": {
    "codex-cc-reviewer": "dist/index.js"
  },
  "files": [
    "dist",
    "prompts",
    "examples",
    "scripts/research-bg-ab.mjs",
    "AGENTS.md",
    "docs/installation.md",
    "docs/manual-setup.md",
    "docs/codex-usage.md",
    "docs/security.md",
    "docs/tool-contract.md",
    "docs/troubleshooting.md",
    "docs/prior-art.md",
    "README.md",
    "README.zh-CN.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:release": "npm run typecheck && npm test && npm run build && npm pack --dry-run --json && node dist/index.js --version && node dist/index.js --help",
    "preflight": "npm ci && npm run verify:release",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "research:bg-ab": "node scripts/research-bg-ab.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.23.0",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
